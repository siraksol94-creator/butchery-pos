{
  "name": "butchery-pro-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "proxy": "http://localhost:5000",
  "dependencies": {
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-router-dom": "^6.20.1",
    "react-scripts": "5.0.1",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0"
  },
  "optionalDependencies": {
    "electron": "^34.5.8"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:electron": "cross-env REACT_APP_API_URL=http://localhost:5000/api react-scripts build",
    "electron": "electron .",
    "electron:dev": "electron .",
    "dist": "npm run build:electron && electron-builder --win"
  },
  "build": {
    "extends": null,
    "appId": "com.sidanit.butcherypro",
    "productName": "Butchery Pro",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "frontend/build"
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!*.db",
          "!*.db-shm",
          "!*.db-wal",
          "!.env"
        ]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
